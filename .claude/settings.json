{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "npm run type-check && npm run lint",
            "statusMessage": "타입 체크 및 린팅 중...",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
